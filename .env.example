PORT=8787
DATABASE_PATH=./data/tideline.db
PHOTON_BASE_URL=https://photon.komoot.io
GEOCODING_USER_AGENT=TideLine/0.1 (+https://example.com; contact: maps@example.com)
DATA_CACHE_MINUTES=30
TIDE_MODEL_PROVIDER=EOT20
EOT20_MODEL_PATH=./data/tide-models
EOT20_MODEL_VERSION=EOT20-85762
EOT20_CACHE_PATH=./data/tide-model-cache
EOT20_PYTHON=./.venv-eot20/Scripts/python.exe
TIDE_RAW_PATH=./data/raw/tides

# Authentication: set these only on the server that owns the database.
# The initial administrator is seeded only when the users table is empty.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=
SESSION_DAYS=7
# Keep true behind HTTPS. For temporary plain-HTTP testing only, explicitly use false.
COOKIE_SECURE=true
# Optional comma-separated local development origins, e.g. http://localhost:5173
ALLOWED_ORIGIN=http://localhost:5173
