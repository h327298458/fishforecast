{
  "name": "tideline-fish-forecast",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c cyan,green \"vite\" \"tsx server/index.ts\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "test": "vitest run --exclude **/*.real.test.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:migrate": "tsx server/db/migrate.ts",
    "tides:import": "tsx scripts/import-official-tides.ts",
    "tides:eot20:validate": "tsx scripts/validate-eot20.ts",
    "test:eot20": "vitest run --config vitest.eot20.config.ts",
    "tides:nsw:download": "powershell -ExecutionPolicy Bypass -File scripts/download-bom-nsw-tides.ps1",
    "tides:nsw:import": "tsx scripts/import-bom-nsw-tides.ts",
    "test:nsw-tides": "vitest run --config vitest.nsw-tides.config.ts"
    ,"tides:compare:validate": "tsx scripts/validate-double-tides.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^10.0.0",
    "better-sqlite3": "^12.11.1",
    "date-fns": "^4.1.0",
    "fast-xml-parser": "^5.10.0",
    "fastify": "^5.10.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.24.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.7.0",
    "suncalc": "^2.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/suncalc": "^1.9.2",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "playwright-core": "^1.61.1",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.0"
  }
}
